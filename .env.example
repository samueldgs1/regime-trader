# ============================================================
# regime_trader — environment variable template
# ============================================================
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must NEVER be committed.
# ============================================================

# ------------------------------------------------------------
# Alpaca credentials
# ------------------------------------------------------------
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
PAPER=true

# ------------------------------------------------------------
# Email alerts (optional — leave blank to disable)
# ------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ------------------------------------------------------------
# Webhook alerts (optional — Slack incoming webhook, Discord, etc.)
# ------------------------------------------------------------
WEBHOOK_URL=
